{
  "name": "local-model-router",
  "productName": "Local Model Router",
  "version": "0.3.0",
  "description": "Local OpenAI-compatible model router with vendor failover.",
  "author": "tang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/landfallbox/local-model-router.git"
  },
  "bugs": {
    "url": "https://github.com/landfallbox/local-model-router/issues"
  },
  "homepage": "https://github.com/landfallbox/local-model-router#readme",
  "keywords": [
    "openai-compatible",
    "model-router",
    "fallback",
    "electron"
  ],
  "type": "module",
  "main": "gui/electron/main.js",
  "scripts": {
    "start": "node src/server.js",
    "check": "node --check src/config.js && node --check src/runtime-config.js && node --check src/logger.js && node --check src/router-urls.js && node --check src/server.js && node --check src/healthcheck.js && node --check gui/electron/config-store.js && node --check gui/electron/log-store.js && node --check gui/electron/main.js && node --check gui/electron/tray-controller.js && node --check gui/electron/updater.js && node --check gui/electron/preload.cjs && node --check gui/src/app-controllers.js && node --check gui/src/app-model.js && node --check gui/src/config-draft.js && node --check gui/src/desktop-api.js && node --check scripts/start-electron-dev.mjs && node --check test/electron-lifecycle.test.js",
    "test": "node test/config-and-urls.test.js && node test/config-draft.test.js && node test/log-store.test.js && node test/fallback-smoke.test.js",
    "test:electron": "node test/electron-lifecycle.test.js",
    "test:ci": "npm test && npm run test:electron",
    "health": "node src/healthcheck.js",
    "gui": "node scripts/start-electron-dev.mjs",
    "gui:dev": "node scripts/start-electron-dev.mjs",
    "gui:update": "node scripts/start-electron-dev.mjs --mock-update",
    "gui:update-error": "node scripts/start-electron-dev.mjs --mock-update-error",
    "gui:build": "vite build --config gui/vite.config.js --configLoader runner",
    "gui:preview": "npm run gui:build && electron .",
    "electron:install": "install-electron",
    "icons:build": "node scripts/build-icons.mjs",
    "dist:windows": "npm run electron:install && npm run icons:build && npm run gui:build && node scripts/prepare-electron-builder.mjs && electron-builder --win nsis --x64",
    "dist:windows:dir": "npm run electron:install && npm run icons:build && npm run gui:build && node scripts/prepare-electron-builder.mjs && electron-builder --win dir --x64"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "42.7.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "sharp": "0.33.5",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "build": {
    "appId": "local.local-model-router",
    "productName": "Local Model Router",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "landfallbox",
        "repo": "local-model-router"
      }
    ],
    "electronDist": "node_modules/electron/dist",
    "files": [
      "package.json",
      "config.example.json",
      "gui/electron/**/*",
      "gui/dist/**/*",
      "src/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "src/**/*",
      "node_modules/zod/**/*"
    ],
    "extraResources": [
      {
        "from": "build/bin",
        "to": "bin",
        "filter": [
          "node.exe"
        ]
      },
      {
        "from": "build/icon.ico",
        "to": "assets/icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "legalTrademarks": "Local Model Router",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${name}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Local Model Router",
      "include": "build/installer.nsh",
      "installerIcon": "build/installerIcon.ico",
      "uninstallerIcon": "build/uninstallerIcon.ico",
      "uninstallDisplayName": "Local Model Router"
    }
  }
}
